pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                echo 'Cloning the GitHub repository'
            }
        }

        stage('Build') {
            steps {
                echo 'Building the simple web project'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests for the project'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying the project'
            }
        }

    }
}